{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "strictNullChecks": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "skipLibCheck": true,
    "declaration": true,
    "noEmit": true
  },
  "include": ["src"],
  "exclude": ["**/node_modules/**", "dist"]
}
